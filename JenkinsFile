def doPull = false;
def needWait = false;
def app_version = null;

pipeline {
  agent any

  options {
    timeout(time: 30, unit: 'MINUTES')
  }

  environment {
    LINKY_API_ENV_FILE = '/var/jenkins_home/envs/linky/.env'
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Compare Local & App Versions') {
      steps {
        script {
          def appVersionResponse = httpRequest url: "https://api.linkynow.site/healthz"
          def appVersionJson = readJSON text: appVersionResponse.content
          appVersion = appVersionJson?.version ?: null

          def localVersionJson = readJSON file: 'package.json'
          def localVersion = localVersionJson?.version ?: null

          if (compareVersions(appVersion, localVersion) <= 0) {
            needWait = true
          }
          echo '✔ Local & App versions compared'
        }
      }
    }

    stage('Wait for Github Actions') {
      when {
        expression { needWait }
      }
      steps {
        sleep time: 3, unit: 'MINUTES'
        echo '✔ Waiting for Github Actions to complete'
      }
    }

    stage('Compare Docker Hub & App Versions') {
      steps {
        withCredentials([string(credentialsId: 'dockerhub-username', variable: 'DOCKERHUB_USERNAME')]) {
          script {
            def tagsDockerHubResponse = httpRequest url: "https://registry.hub.docker.com/v2/repositories/$DOCKERHUB_USERNAME/linky-api/tags"
            def tagsDockerHubJson = readJSON text: tagsDockerHubResponse.content

            def latestDigest = tagsDockerHubJson.results.find { tag -> tag.name == "latest" }?.images[0]?.digest

            def matchedTag = latestDigest ? tagsDockerHubJson.results.find { tag -> tag.name != "latest" &&  tag.images.any { img -> img.digest == latestDigest } }  : null
            doPull = compareVersions(app_version, matchedTag?.name) == -1
            echo '✔ Docker Hub & App versions compared'
          }
        }
      }
    }

    stage('Prepare Env Files') {
      when {
        expression { doPull }
      }
      steps {
        withCredentials([file(credentialsId: 'linky-api-env-file', variable: 'ENV_FILE')]) {
          sh '''
            mkdir -p /var/jenkins_home/envs/linky
            cp "$ENV_FILE" "$LINKY_API_ENV_FILE"
            chmod 600 "$LINKY_API_ENV_FILE"
          '''
          echo '✔ Env files prepared'
        }
      }
    }

    stage('Deploy Linky') {
      when {
        expression { doPull }
      }
      steps {
        sh '''
          docker compose down || true
          docker compose pull
          docker compose up -d --build
        '''
      }
    }

  } // end stages

  post {
    always {
      cleanWs()
    }
    success {
      echo '✔ Linky deployed successfully'
    }
    failure {
      echo '✘ Linky deployment failed'
    }
  }
}
