def doPull = false;
def localVersion = null;
def remoteVersion = null;

pipeline {
  agent any

  options {
    timeout(time: 15, unit: 'MINUTES')
  }

  environment {
    LINKY_API_URL = 'https://api.linkynow.site'
    DOCKER_IMAGE_API_URL = 'https://registry.hub.docker.com/v2/repositories/mewthedev/linky-api'
    DOCKER_IMAGE_WORKER_AI_URL = 'https://registry.hub.docker.com/v2/repositories/mewthedev/linky-worker-ai'
    DOCKER_IMAGE_WORKER_JOBS_URL = 'https://registry.hub.docker.com/v2/repositories/mewthedev/linky-worker-jobs'
  }

  stages {

    stage('Checkout Code') {
      steps {
        checkout scm
      }
    }

    stage('Live vs Repo Version') {
      steps {
        script {
          echo '- Checking local & remote versions'

          def localVersionResponse = httpRequest url: "$LINKY_API_URL/healthz"
          def localVersionJson = readJSON text: localVersionResponse.content
          localVersion = localVersionJson?.version ?: null

          def remoteVersionJson = readJSON file: 'package.json'
          remoteVersion = remoteVersionJson?.version ?: null

          echo "- Local version: $localVersion"
          echo "- Remote version: $remoteVersion"

          def compareResult = compareVersions v1: localVersion, v2: remoteVersion
          def compareResultMessage = compareResult == 0 ? 'matched' : compareResult == 1 ? 'newer' : 'older'
          echo "- Compare result: $compareResultMessage"

          if (compareResult <= 0) {
            doPull = true
          }
          echo "✔ Local & Remote versions compared"
        }
      }
    }

    stage('Docker Image Sync') {
      steps {
        script {
          waitUntil {
            sleep time: 10, unit: 'SECONDS'

            echo '- Checking Docker Hub & Remote versions'

            def tagsDockerHubResponse = httpRequest url: "$DOCKER_IMAGE_API_URL/tags"
            def tagsDockerHubJson = readJSON text: tagsDockerHubResponse.content

            def tagsDockerHubWorkerAiResponse = httpRequest url: "$DOCKER_IMAGE_WORKER_AI_URL/tags"
            def tagsDockerHubWorkerAiJson = readJSON text: tagsDockerHubWorkerAiResponse.content

            def tagsDockerHubWorkerJobsResponse = httpRequest url: "$DOCKER_IMAGE_WORKER_JOBS_URL/tags"
            def tagsDockerHubWorkerJobsJson = readJSON text: tagsDockerHubWorkerJobsResponse.content

            def latestDigestMain = tagsDockerHubJson.results.find { tag -> tag.name == "latest" }?.images[0]?.digest
            def matchedTagMain = latestDigestMain
              ? tagsDockerHubJson.results.find { tag ->
                  tag.name != "latest" && tag.images.any { img -> img.digest == latestDigestMain }
                }
              : null

            def latestDigestWorkerAi = tagsDockerHubWorkerAiJson.results.find { tag -> tag.name == "latest" }?.images[0]?.digest
            def matchedTagWorkerAi = latestDigestWorkerAi
              ? tagsDockerHubWorkerAiJson.results.find { tag ->
                  tag.name != "latest" && tag.images.any { img -> img.digest == latestDigestWorkerAi }
                }
              : null

            def latestDigestWorkerJobs = tagsDockerHubWorkerJobsJson.results.find { tag -> tag.name == "latest" }?.images[0]?.digest
            def matchedTagWorkerJobs = latestDigestWorkerJobs
              ? tagsDockerHubWorkerJobsJson.results.find { tag ->
                  tag.name != "latest" && tag.images.any { img -> img.digest == latestDigestWorkerJobs }
                }
              : null

            def dockerMainVersion = matchedTagMain?.name
            def dockerWorkerAiVersion = matchedTagWorkerAi?.name
            def dockerWorkerJobsVersion = matchedTagWorkerJobs?.name

            echo "Docker Hub main version: ${dockerMainVersion}"
            echo "Docker Hub worker-ai version: ${dockerWorkerAiVersion}"
            echo "Docker Hub worker-jobs version: ${dockerWorkerJobsVersion}"
            echo "Remote version: ${remoteVersion}"
            echo "Local version: ${localVersion}"

            def allDockerVersionsSame =
              dockerMainVersion &&
              dockerWorkerAiVersion &&
              dockerWorkerJobsVersion &&
              compareVersions(v1: dockerMainVersion, v2: dockerWorkerAiVersion) == 0 &&
              compareVersions(v1: dockerMainVersion, v2: dockerWorkerJobsVersion) == 0

            def allDockerMatchRemote =
              allDockerVersionsSame &&
              compareVersions(v1: remoteVersion, v2: dockerMainVersion) == 0

            if (allDockerMatchRemote) {
              echo '✔ All 3 Docker Hub versions are the same'
              echo '✔ Docker Hub & Remote versions are the same'

              def allDockerMatchLocal =
                compareVersions(v1: localVersion, v2: dockerMainVersion) == 0 &&
                compareVersions(v1: localVersion, v2: dockerWorkerAiVersion) == 0 &&
                compareVersions(v1: localVersion, v2: dockerWorkerJobsVersion) == 0

              if (allDockerMatchLocal) {
                echo '✔ Docker Hub & Local versions are the same'
                echo '✔ No need to deploy'
                doPull = false
              }

              return true
            }

            echo '△ Docker Hub versions are not fully synced with Remote yet'
            echo '△ Waiting for Github Actions to complete'
            return false
          }
        }
      }
    }

    stage('Prepare Env') {
      when {
        expression { doPull }
      }
      steps {
        withCredentials([file(credentialsId: 'linky-api-env-file', variable: 'ENV_FILE')]) {
          sh '''
            cp "$ENV_FILE" .env
            chmod 600 .env
          '''
          echo '✔ Env files prepared'
        }
      }
    }

    stage('Deploy') {
      when {
        expression { doPull }
      }
      steps {
        sh '''
          docker compose up -d --pull always
        '''
      }
    }
  }

  post {
    always {
      cleanWs()
    }
    success {
      echo '✔ Linky deployed successfully'
    }
    failure {
      echo '✘ Linky deployment failed'
    }
  }
}
