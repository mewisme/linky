pipeline {
  agent any

  tools {
    nodejs 'node-lts'
  }

  options {
    timeout(time: 30, unit: 'MINUTES')
  }

  environment {
    BACKEND_IMAGE = 'linky-api:latest'
    LINKY_API_ENV_FILE = '/var/jenkins_home/envs/linky/.env'
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Check API changes') {
      steps {
        script {
          def changed = sh(
            script: "git diff --name-only origin/main...HEAD | grep '^apps/api/' || true",
            returnStdout: true
          ).trim()

          if (!changed) {
            currentBuild.result = 'SUCCESS'
            error("No changes in apps/api/, skipping pipeline")
          }

          echo "Detected changes in apps/api"
        }
      }
    }

    stage('Prepare Env Files') {
      steps {
        withCredentials([file(credentialsId: 'linky-api-env-file', variable: 'ENV_FILE')]) {
          sh '''
            mkdir -p /var/jenkins_home/envs/linky
            cp "$ENV_FILE" "$LINKY_API_ENV_FILE"
            chmod 600 "$LINKY_API_ENV_FILE"
          '''
        }
      }
    }

    stage('Docker Build Backend (Express.js)') {
      steps {
        script {
          def backendImage = docker.build("${BACKEND_IMAGE}", "-f apps/api/Dockerfile .")
          env.BACKEND_IMAGE_ID = backendImage.id
        }
      }
    }

    stage('Deploy Backend (Express.js)') {
      steps {
        sh '''
          docker compose down || true
          docker rm -f linky-api linky-redis || true
          docker compose up -d
        '''
      }
    }

  } // end stages

  post {
    always {
      cleanWs()
    }
    success {
      echo 'Backend deployed successfully'
    }
    failure {
      echo 'Backend deployment failed'
    }
  }
}
