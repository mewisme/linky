def doPull = false;
def localVersion = null;
def remoteVersion = null;

pipeline {
  agent any

  options {
    timeout(time: 30, unit: 'MINUTES')
  }

  environment {
    LINKY_API_ENV_FILE = '/var/jenkins_home/envs/linky/.env'
    DOCKERHUB_USERNAME = 'mewthedev'
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Compare Local & Remote Versions') {
      steps {
        script {
          def localVersionResponse = httpRequest url: "https://api.linkynow.site/healthz"
          def localVersionJson = readJSON text: localVersionResponse.content
          localVersion = localVersionJson?.version ?: null

          def remoteVersionJson = readJSON file: 'package.json'
          remoteVersion = remoteVersionJson?.version ?: null

          echo "- Local version: $localVersion"
          echo "- Remote version: $remoteVersion"

          def compareResult = compareVersions v1: localVersion, v2: remoteVersion
          echo "- Compare result: $compareResult"

          if (compareResult <= 0) {
            doPull = true
          }
          echo '✔ Local & Remote versions compared'
        }
      }
    }

    stage('Compare Docker Hub & Remote Versions') {
      steps {
        script {
          timeout(time: 5, unit: 'MINUTES') {
            waitUntil {
              sleep time: 10, unit: 'SECONDS'

              echo '- Checking Docker Hub & Remote versions'

              def tagsDockerHubResponse = httpRequest url: "https://registry.hub.docker.com/v2/repositories/$DOCKERHUB_USERNAME/linky-api/tags"
              def tagsDockerHubJson = readJSON text: tagsDockerHubResponse.content

              def latestDigest = tagsDockerHubJson.results.find { tag -> tag.name == "latest" }?.images[0]?.digest
              def matchedTag = latestDigest ? tagsDockerHubJson.results.find { tag -> tag.name != "latest" &&  tag.images.any { img -> img.digest == latestDigest } }  : null

              def compareRemoteResult = compareVersions v1: remoteVersion, v2: matchedTag?.name
              
              if (compareRemoteResult == 0) {
                echo '✔ Docker Hub & Remote versions are the same'

                def compareLocalResult = compareVersions v1: localVersion, v2: matchedTag?.name
                if (compareLocalResult == 0) {
                  echo '✔ Docker Hub & Local versions are the same'
                  echo '✔ No need to deploy'

                  doPull = false
                }

                return true
              }

              echo '△ Docker Hub & Remote versions are different'
              echo '△ Waiting for Github Actions to complete'
              return false
            }
          }
        }
      }
    }

    stage('Prepare Env Files') {
      when {
        expression { doPull }
      }
      steps {
        withCredentials([file(credentialsId: 'linky-api-env-file', variable: 'ENV_FILE')]) {
          sh '''
            mkdir -p /var/jenkins_home/envs/linky
            cp "$ENV_FILE" "$LINKY_API_ENV_FILE"
            chmod 600 "$LINKY_API_ENV_FILE"
          '''
          echo '✔ Env files prepared'
        }
      }
    }

    stage('Deploy Linky') {
      when {
        expression { doPull }
      }
      steps {
        sh '''
          docker compose down || true
          docker compose pull
          docker compose up -d --build
        '''
      }
    }

  } // end stages

  post {
    always {
      cleanWs()
    }
    success {
      echo '✔ Linky deployed successfully'
    }
    failure {
      echo '✘ Linky deployment failed'
    }
  }
}
