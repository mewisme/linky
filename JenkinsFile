pipeline {
  agent any

  tools {
    nodejs 'node-lts'
  }

  options {
    timeout(time: 30, unit: 'MINUTES')
  }

  environment {
    BACKEND_IMAGE = 'linky-api:latest'
    LINKY_API_ENV_FILE = '/var/jenkins_home/envs/linky/.env'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Dependencies') {
      steps {
        sh '''
          corepack enable
          pnpm install --frozen-lockfile
        '''
      }
    }

    stage('Prepare Env Files') {
      steps {
        withCredentials([file(credentialsId: 'linky-api-env-file', variable: 'ENV_FILE')]) {
          sh '''
            mkdir -p /var/jenkins_home/envs/linky
            cp "$ENV_FILE" "$LINKY_API_ENV_FILE"
            chmod 600 "$LINKY_API_ENV_FILE"
          '''
        }
      }
    }
    
    stage('Docker Build Backend (Express.js)') {
      steps {
        script {
          def backendImage = docker.build("${BACKEND_IMAGE}", "-f apps/api/Dockerfile .")
          env.BACKEND_IMAGE_ID = backendImage.id
        }
      }
    }
    
    stage('Deploy Backend (Express.js)') {
      steps {
        script {
          sh '''
            docker compose down || true
            docker rm -f linky-api linky-redis
            docker compose up -d
          '''
        }
      }
    }
  }

  post {
    always {
      cleanWs()
    }
    success {
      echo 'Turbo monorepo deploy successfully'
    }
    failure {
      echo 'Pipeline failed'
    }
  }
}