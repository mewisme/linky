pipeline {
  agent any

  tools {
    nodejs 'node-lts'
  }

  options {
    timeout(time: 30, unit: 'MINUTES')
  }

  environment {
    BACKEND_IMAGE = 'linky-api:latest'
    LINKY_API_ENV_FILE = '/var/jenkins_home/envs/linky/.env'
    SKIP_BUILD = 'false'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Check Version') {
      steps {
        script {
          withCredentials([
            string(credentialsId: 'linky-api-url', variable: 'API_URL'),
            string(credentialsId: 'linky-github-token', variable: 'GITHUB_TOKEN')
          ]) {
            try {
              def jsonSlurper = new groovy.json.JsonSlurper()

              def apiResponse = sh(
                script: "curl -s ${API_URL}",
                returnStdout: true
              ).trim()

              echo "API Response: ${apiResponse}"

              def apiData = jsonSlurper.parseText(apiResponse)
              if (!apiData.version) {
                error("API response missing version")
              }

              def deployedVersion = apiData.version
              echo "Deployed version: ${deployedVersion}"

              def packageJsonRaw = sh(
                script: '''
                  curl -s -H "Authorization: Bearer ${GITHUB_TOKEN}" \
                      -H "Accept: application/json" \
                      https://raw.githubusercontent.com/mewisme/linky/refs/heads/main/apps/api/package.json
                ''',
                returnStdout: true
              ).trim()

              echo "Package JSON Raw: ${packageJsonRaw}"

              def packageJson = jsonSlurper.parseText(packageJsonRaw)
              def currentVersion = packageJson.version
              echo "Package JSON: ${packageJson}"
              echo "Current version: ${currentVersion}"

              if (deployedVersion == currentVersion) {
                echo "Versions match. Skipping build."
                env.SKIP_BUILD = 'true'
              } else {
                echo "Versions differ. Proceeding with build."
                env.SKIP_BUILD = 'false'
              }
            } catch (Exception e) {
              echo "Version check failed: ${e.message}. Proceeding with build."
              env.SKIP_BUILD = 'false'
            }
          }
        }
      }
    }

    stage('Install Dependencies') {
      when {
        expression { env.SKIP_BUILD == 'false' }
      }
      steps {
        sh '''
          corepack enable
          pnpm install --frozen-lockfile
        '''
      }
    }

    stage('Prepare Env Files') {
      when {
        expression { env.SKIP_BUILD == 'false' }
      }
      steps {
        withCredentials([file(credentialsId: 'linky-api-env-file', variable: 'ENV_FILE')]) {
          sh '''
            mkdir -p /var/jenkins_home/envs/linky
            cp "$ENV_FILE" "$LINKY_API_ENV_FILE"
            chmod 600 "$LINKY_API_ENV_FILE"
          '''
        }
      }
    }
    
    stage('Docker Build Backend (Express.js)') {
      when {
        expression { env.SKIP_BUILD == 'false' }
      }
      steps {
        script {
          def backendImage = docker.build("${BACKEND_IMAGE}", "-f apps/api/Dockerfile .")
          env.BACKEND_IMAGE_ID = backendImage.id
        }
      }
    }
    
    stage('Deploy Backend (Express.js)') {
      when {
        expression { env.SKIP_BUILD == 'false' }
      }
      steps {
        script {
          sh '''
            docker compose down || true
            docker rm -f linky-api linky-redis
            docker compose up -d
          '''
        }
      }
    }
  }

  post {
    always {
      cleanWs()
    }
    success {
      echo 'Turbo monorepo deploy successfully'
    }
    failure {
      echo 'Pipeline failed'
    }
  }
}