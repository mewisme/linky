{
  "name": "@ws/api",
  "version": "0.75.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./worker-ai": {
      "types": "./src/worker/ai-job-executor.d.ts",
      "import": "./dist/worker/ai-job-executor.js"
    },
    "./worker-jobs": {
      "types": "./src/worker/jobs-job-executor.d.ts",
      "import": "./dist/worker/jobs-job-executor.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --import=./src/instrument.ts src/index.ts",
    "prebuild": "pnpm check-types",
    "build": "tsup",
    "start": "node --import=dist/instrument.js dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/lib-storage": "^3.1021.0",
    "@aws-sdk/s3-request-presigner": "^3.1021.0",
    "@clerk/backend": "^2.33.1",
    "@sentry/node": "^10.47.0",
    "@supabase/supabase-js": "^2.101.1",
    "@ws/logger": "workspace:*",
    "@ws/sdk-internal": "workspace:*",
    "@ws/shared-types": "workspace:*",
    "@ws/validation": "workspace:*",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "catalog:",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "ollama": "^0.6.3",
    "redis": "catalog:",
    "socket.io": "catalog:",
    "svix": "^1.89.0",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@ws/eslint-config": "workspace:*",
    "@ws/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
