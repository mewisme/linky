{
  "name": "@ws/api",
  "version": "0.72.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch --import=./src/instrument.ts src/index.ts",
    "prebuild": "pnpm check-types",
    "build": "tsup",
    "start": "node --import=dist/instrument.js dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/lib-storage": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@clerk/backend": "^2.33.1",
    "@sentry/node": "^10.45.0",
    "@supabase/supabase-js": "^2.100.0",
    "@ws/logger": "workspace:*",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "mqtt": "^5.15.1",
    "node-cron": "^4.2.1",
    "ollama": "^0.6.3",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "svix": "^1.89.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.1",
    "@ws/eslint-config": "workspace:*",
    "@ws/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "^4.1.1"
  }
}
