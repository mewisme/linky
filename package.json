{
  "name": "linky",
  "version": "0.71.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@ws/api",
    "build:web": "turbo run build --filter=@ws/web",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@ws/api",
    "dev:web": "turbo run dev --filter=@ws/web",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=@ws/api",
    "start:web": "turbo run start --filter=@ws/web",
    "lint": "turbo run lint",
    "lint:api": "turbo run lint --filter=@ws/api",
    "lint:web": "turbo run lint --filter=@ws/web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-types:api": "turbo run check-types --filter=@ws/api",
    "check-types:web": "turbo run check-types --filter=@ws/web",
    "test": "pnpm exec playwright test",
    "test:ui": "pnpm exec playwright test --ui",
    "test:debug": "pnpm exec playwright test --debug",
    "test:trace": "pnpm exec playwright test --trace",
    "test:report": "pnpm exec playwright show-report",
    "test:codegen": "pnpm exec playwright codegen",
    "upver": "node scripts/generate-changelog.js && node scripts/version-upgrade.js"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "catalog:",
    "dotenv": "^17.3.1",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "catalog:"
  }
}
