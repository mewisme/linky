{
  "name": "linky",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@ws/api",
    "build:web": "turbo run build --filter=@ws/web",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@ws/api",
    "dev:worker": "turbo run dev --filter=@ws/worker",
    "dev:web": "turbo run dev --filter=@ws/web",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=@ws/api",
    "start:web": "turbo run start --filter=@ws/web",
    "start:worker": "turbo run start --filter=@ws/worker",
    "lint": "turbo run lint",
    "lint:api": "turbo run lint --filter=@ws/api",
    "lint:web": "turbo run lint --filter=@ws/web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-types:api": "turbo run check-types --filter=@ws/api",
    "check-types:web": "turbo run check-types --filter=@ws/web",
    "docker:build:api": "docker build -f apps/api/Dockerfile -t linky-api:local .",
    "docker:build:worker": "docker build -f apps/worker/Dockerfile -t linky-worker:local .",
    "test": "pnpm exec playwright test",
    "test:ui": "pnpm exec playwright test --ui",
    "test:debug": "pnpm exec playwright test --debug",
    "test:trace": "pnpm exec playwright test --trace",
    "test:report": "pnpm exec playwright show-report",
    "test:report:last": "node scripts/playwright-show-last-report.mjs",
    "test:report:excel": "node scripts/playwright-json-to-excel.mjs",
    "test:codegen": "pnpm exec playwright codegen",
    "upver": "node scripts/generate-changelog.js && node scripts/version-upgrade.js"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "25.6.0",
    "dotenv": "catalog:",
    "prettier": "^3.8.3",
    "turbo": "^2.9.9",
    "typescript": "catalog:",
    "xlsx": "^0.18.5"
  }
}
