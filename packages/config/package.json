{
  "name": "@ws/config",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm check-types",
    "build": "tsc",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@ws/typescript-config": "workspace:*",
    "typescript": "catalog:"
  }
}
