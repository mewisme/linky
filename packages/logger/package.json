{
  "name": "@ws/logger",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm check-types",
    "build": "tsc",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@sentry/node": "^10.50.0",
    "@types/node": "25.6.0",
    "@ws/eslint-config": "workspace:*",
    "@ws/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "license": "MIT"
}
